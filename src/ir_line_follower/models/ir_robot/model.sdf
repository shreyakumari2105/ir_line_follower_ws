<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="ir_robot">
    <link name="base_link">
      <inertial><mass>2.0</mass><inertia><ixx>0.05</ixx><iyy>0.05</iyy><izz>0.05</izz></inertia></inertial>
      <collision name="col"><geometry><box><size>0.2 0.15 0.06</size></box></geometry></collision>
      <visual name="vis">
        <geometry><box><size>0.2 0.15 0.06</size></box></geometry>
        <material><ambient>0.9 0.5 0.1 1</ambient><diffuse>0.9 0.5 0.1 1</diffuse></material>
      </visual>
    </link>
    <link name="left_wheel">
      <pose>0 0.1 0 -1.5707 0 0</pose>
      <inertial><mass>0.5</mass><inertia><ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz></inertia></inertial>
      <collision name="col"><geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry></collision>
      <visual name="vis">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>
    <link name="right_wheel">
      <pose>0 -0.1 0 -1.5707 0 0</pose>
      <inertial><mass>0.5</mass><inertia><ixx>0.005</ixx><iyy>0.005</iyy><izz>0.005</izz></inertia></inertial>
      <collision name="col"><geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry></collision>
      <visual name="vis">
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>
    <link name="caster_front">
      <pose>0.08 0 -0.03 0 0 0</pose>
      <inertial><mass>0.1</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
      <collision name="col"><geometry><sphere><radius>0.02</radius></sphere></geometry><surface><friction><ode><mu>0</mu><mu2>0</mu2></ode></friction></surface></collision>
      <visual name="vis"><geometry><sphere><radius>0.02</radius></sphere></geometry><material><ambient>0.5 0.5 0.5 1</ambient></material></visual>
    </link>
    <link name="caster_rear">
      <pose>-0.08 0 -0.03 0 0 0</pose>
      <inertial><mass>0.1</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
      <collision name="col"><geometry><sphere><radius>0.02</radius></sphere></geometry><surface><friction><ode><mu>0</mu><mu2>0</mu2></ode></friction></surface></collision>
      <visual name="vis"><geometry><sphere><radius>0.02</radius></sphere></geometry><material><ambient>0.5 0.5 0.5 1</ambient></material></visual>
    </link>
    <link name="ir_camera_link">
      <pose>0.09 0 -0.025 0 1.5707 0</pose>
      <inertial><mass>0.01</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial>
      <sensor name="ir_array_camera" type="camera">
        <topic>/camera/image_raw</topic>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>0.6</horizontal_fov>
          <image><width>160</width><height>120</height><format>R8G8B8</format></image>
          <clip><near>0.01</near><far>1.0</far></clip>
        </camera>
        <gz_frame_id>ir_camera_link</gz_frame_id>
      </sensor>
    </link>
    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent><child>left_wheel</child><axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent><child>right_wheel</child><axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint name="caster_front_joint" type="ball"><parent>base_link</parent><child>caster_front</child></joint>
    <joint name="caster_rear_joint"  type="ball"><parent>base_link</parent><child>caster_rear</child></joint>
    <joint name="ir_camera_joint" type="fixed"><parent>base_link</parent><child>ir_camera_link</child></joint>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.2</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <odom_publish_frequency>10</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </model>
</sdf>